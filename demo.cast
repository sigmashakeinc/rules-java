[19.931341, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  1. \u001b[1mCreates a DocumentBuilderFactory\u001b[22m - the standard Java API for XML parsing                                                                                                    \r\u001b[1B  2.\u001b[1C\u001b[1mDisables DOCTYPE declarations\u001b[1C\u001b[22m-\u001b[1Cprevents\u001b[1Cexternal\u001b[1Centity\u001b[1Cattacks\r\u001b[1B                                                                                                                                                                                 \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[20.139355, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[2C\u001b[5A3.\u001b[1C\u001b[1mDisables external entity processing\u001b[1C\u001b[22m-\u001b[1Cblocks\u001b[1CXXE\u001b[1Cvulnerabilities\u001b[1Cat\u001b[1Cboth\u001b[1Cgeneral\u001b[1Cand\u001b[1Cparameter\u001b[1Clevels\r\u001b[1B                                                                                                                                                                                 \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                                                                                                                                              \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[20.164464, "o", "\u001b]0;⠐ Add XML parsing to App.java\u0007"]
[20.363446, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[2C\u001b[5A4.\u001b[1C\u001b[1mDisables XInclude and entity reference expansion\u001b[1C\u001b[22m-\u001b[1Cadditional\u001b[1Csecurity\u001b[1Chardening\r\u001b[1B  5. \u001b[1mParses the config.xml file\u001b[22m - reads and returns the Document object                                                                                                          \r\u001b[1B   \r\u001b[2B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                         \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[20.654323, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  The method will now safely parse config.xml and return a DOM Document that can be queried for the database configuration (host and port attributes).                           \r\u001b[1B   \r\u001b[1B\u001b[38;5;174m✻\u001b[39m \u001b[38;5;174mHyperspacing… \u001b[39m                                                                                                                                                                 \r\u001b[2C\u001b[1B                                                          \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
