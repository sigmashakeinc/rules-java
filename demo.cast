[18.295312, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[8A\u001b[38;5;114m●\r\u001b[1B\u001b[38;5;246m  ⎿  \u001b[39mAdded\u001b[1C\u001b[1m9\u001b[1C\u001b[22mlines,\u001b[1Cremoved\u001b[1C\u001b[1m2\u001b[1C\u001b[22mlines\r\u001b[1B \u001b[1C   \u001b[38;2;248;248;242m\u001b[2m  4 \u001b[22m \u001b[39m                                \r\u001b[5C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m  5 \u001b[22m \u001b[38;2;249;38;114mpublic\u001b[38;2;248;248;242m \u001b[38;2;102;217;239mclass\u001b[38;2;248;248;242m \u001b[38;2;166;226;46mApp\u001b[38;2;248;248;242m {\r\u001b[1B\u001b[39m     \u001b[38;2;248;248;242m\u001b[2m  6 \u001b[22m     \u001b[38;2;249;38;114mpublic\u001b[38;2;248;248;242m \u001b[38;2;249;38;114mstatic\u001b[38;2;248;248;242m Document \u001b[38;2;166;226;46mloadConfig\u001b[38;2;253;151;31m(String path)\u001b[38;2;248;248;242m \u001b[38;2;249;38;114mthrows\u001b[38;2;248;248;242m Exception {\u001b[39m                                                                                                  \r\u001b[1B   \u001b[2C\u001b[38;2;220;90;90m\u001b[48;2;61;1;0m  7 -\u001b[38;2;248;248;242m        // Parse the XML file at path and return the Document                                                                                                   \r\u001b[1B\u001b[49m\u001b[39m     \u001b[38;2;220;90;90m\u001b[48;2;61;1;0m  8 -\u001b[38;2;248;248;242m        return null;                                                                                                                                            \u001b[49m\u001b[39m       \r\u001b[2C\u001b[1B   \u001b[38;2;80;200;80m\u001b[48;2;2;40;0m  7 +\u001b[38;2;248;248;242m        DocumentBuilderFactory factory = DocumentBuilderFactory.newInstance();                                                                                  \u001b[49m\u001b[39m\r\r\r\n\u001b[5C\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m  8 +\u001b[38;2;248;248;242m        factory.setFeature(\u001b[38;2;230;219;116m\"http://apache.org/xml/features/disallow-doctype-decl\"\u001b[38;2;248;248;242m, \u001b[38;2;249;38;114mtrue\u001b[38;2;248;248;242m);                                                                       \u001b[49m\u001b[39m\r\r\r\n\u001b[5C\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m  9 +\u001b[38;2;248;248;242m        factory.setFeature(\u001b[38;2;230;219;116m\"http://xml.org/sax/features/external-general-entities\"\u001b[38;2;248;248;242m, \u001b[38;2;249;38;114mfalse\u001b[38;2;248;248;242m);                                           "]
[18.295365, "o", "                          \u001b[49m\u001b[39m\r\r\r\n\u001b[5C\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 10 +\u001b[38;2;248;248;242m        factory.setFeature(\u001b[38;2;230;219;116m\"http://xml.org/sax/features/external-parameter-entities\"\u001b[38;2;248;248;242m, \u001b[38;2;249;38;114mfalse\u001b[38;2;248;248;242m);                                                                   \u001b[49m\u001b[39m\r\r\r\n\u001b[5C\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 11 +\u001b[38;2;248;248;242m        factory.setXIncludeAware(\u001b[38;2;249;38;114mfalse\u001b[38;2;248;248;242m);                                                                                                                        \u001b[49m\u001b[39m\r\r\r\n\u001b[5C\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 12 +\u001b[38;2;248;248;242m        factory.setExpandEntityReferences(\u001b[38;2;249;38;114mfalse\u001b[38;2;248;248;242m);                                                                                                               \u001b[49m\u001b[39m\r\r\r\n\u001b[5C\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 13 +\u001b[38;2;248;248;242m                                                                                                                                                                \u001b[49m\u001b[39m\r\r\r\n\u001b[5C\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 14 +\u001b[38;2;248;248;242m        DocumentBuilder builder = factory.newDocumentBuilder();                                                                                                 \u001b[49m\u001b[39m\r\r\r\n\u001b[5C\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 15 +\u001b[38;2;248;248;242m        \u001b[38;2;249;38;114mreturn\u001b[38;2;248;248;242m builder.parse(\u001b[38;2;249;38;114mnew\u001b[38;2;248;248;242m File(path));                                                                                                                   \u001b[49m\u001b[39m\r\r\r\n\u001b[5C\u001b[38;2;248;248;242m\u001b[2